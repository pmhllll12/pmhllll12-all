# auth 컨테이너 전용 — 이 파일만 auth 서비스의 env_file로 쓰인다(백엔드의 .env와 분리).
# `.env.auth`로 복사한 뒤 값을 채우세요.

# scripts/generate_jwt_keys.sh 로 생성. PEM 그대로 또는 base64 한 줄 둘 다 가능.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# 여러 키로 로테이션할 때 구분용 kid. 기본값 authgw-1.
JWT_KID=authgw-1

# 발급하는 access token의 aud — 백엔드(core/config.py의 API_AUD)와 반드시 같은 값.
API_AUD=api

# 쿠키 domain — 서브도메인(auth./api.) 모두에서 쿠키가 전달되도록 앞에 점을 붙인다.
AUTH_COOKIE_DOMAIN=.pmhllll12.cloud

# 리프레시 토큰 회전 상태 저장. Docker Compose 내부에서는 redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# oauth state 서명용 무작위 문자열(main.py의 SESSION_SECRET과 같은 용도, 값은
# 공유해도 되고 별도로 발급해도 됨 — python -c "import secrets;print(secrets.token_urlsafe(32))")
SESSION_SECRET=

# 구글/네이버/카카오 — 기존 main.py OAuth 라우트와 별개 redirect URI를 쓴다
# (이 서비스는 /auth/callback/{provider}, 기존 라우트는 /auth/{provider}/callback).
# 각 provider 콘솔에 아래 redirect URI를 추가로 등록해야 한다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 로컬: http://127.0.0.1:9000/auth/callback/google
# 운영: https://auth.pmhllll12.cloud/auth/callback/google
GOOGLE_REDIRECT_URI=http://127.0.0.1:9000/auth/callback/google

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://127.0.0.1:9000/auth/callback/naver

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://127.0.0.1:9000/auth/callback/kakao
