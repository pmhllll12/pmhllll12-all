# 이 파일을 `.env` 로 복사한 뒤 값을 채우세요 (`.env` 는 Git에 올리지 마세요).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_복사한_키_붙여넣기

# 선택 (기본: gemini-2.5-flash — 2.0-flash 무료 한도 limit:0 인 경우 많음)
# GEMINI_MODEL=gemini-2.5-flash

# Navbar 서울 날씨 (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Neon PostgreSQL (James CSV 업로드·회원가입 등)
# 대시보드 Connection string — sslmode 는 database.py 에서 없으면 require 로 보완
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ontology 크롤러/스크래퍼가 대상(website/keyword)을 읽어오는 Redis
# 로컬: redis://localhost:6379/0, Docker Compose 내부: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# 구글 로그인 (https://console.cloud.google.com/apis/credentials 에서 OAuth 클라이언트 ID 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 로컬: http://127.0.0.1:8000/auth/google/callback
# 운영: https://api.pmhllll12.cloud/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

# oauth state 서명용 무작위 문자열 (예: python -c "import secrets;print(secrets.token_urlsafe(32))")
SESSION_SECRET=
