# 백엔드(main.py) 컨테이너 전용 추가 env_file — JWT 검증부만 있으면 되므로
# 개인키는 담지 않는다. `.env.backend`로 복사한 뒤 값을 채우세요.
# (backend는 이 파일과 기존 .env를 함께 읽는다 — docker-compose.yaml 참고)

# scripts/generate_jwt_keys.sh 로 생성한 jwt_public.pem 내용(PEM 또는 base64).
# auth 컨테이너의 JWT_PUBLIC_KEY와 반드시 같은 값이어야 한다.
JWT_PUBLIC_KEY=

# auth가 발급하는 토큰의 aud와 반드시 같은 값 (.env.auth의 API_AUD 참고).
API_AUD=api
